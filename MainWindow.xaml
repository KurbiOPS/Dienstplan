<Window x:Class="MeineWPFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MeineWPFApp"
        mc:Ignorable="d"
            Title="MainWindow" Height="750" Width="1500" Background="White">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Right" Margin="0,10,10,0">
            <Button x:Name="btnSave" Content="Speichern" Width="100" Height="30" Click="btnSave_Click" FontSize="14" FontWeight="Bold"/>
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <Button x:Name="btnAddRow" Content="+" Width="40" Height="40" Margin="0,0,15,0" Click="btnAddRow_Click" FontSize="16" FontWeight="Bold"/>
                    <Button x:Name="btnRemoveRow" Content="-" Width="40" Height="40" Click="btnRemoveRow_Click" FontSize="16" FontWeight="Bold"/>
                </StackPanel>
                <Grid Margin="25,25,25,0" x:Name="mainGrid">
                    <!-- Grid content will be populated dynamically -->
                </Grid>
            </DockPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
