<Window x:Class="MeineWPFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MeineWPFApp"
        mc:Ignorable="d"
            Title="MainWindow" Height="450" Width="800" Background="Black">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="Vorname: " Margin="0,0,0,5"/>
            <TextBox x:Name="txtVorname" Width="200" HorizontalAlignment="Left" />


            <Button Content="Absenden" Click="Button_Click" Margin="0,10,0,0" Width="100" />
        </StackPanel> 
    </Grid>
</Window>
